{
  "name": "portfolio2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^6.30.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "build:server": "npm run build --prefix server",
    "dev:all": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npm run db:migrate --prefix server"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
