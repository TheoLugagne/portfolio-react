PORT=4000

# PostgreSQL distant — remplacez par l'URL de votre serveur
# Exemple : postgresql://user:pass@db.example.com:5432/portfolio?sslmode=require
DATABASE_URL=postgresql://user:password@your-db-server.example.com:5432/portfolio2

# SSL requis pour la plupart des hébergeurs distants (Supabase, Neon, Railway, VPS…)
# Valeurs : require | false  (ou laissez vide si sslmode est déjà dans DATABASE_URL)
DATABASE_SSL=require

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
JWT_SECRET=change-me-in-production
ADMIN_EMAILS=admin@example.com
STORAGE_PATH=./uploads
CORS_ORIGIN=http://localhost:3000
